{% set version = tetris_version | default(bookshelf_const_version.tetris, true) %}
{% set web_ui_port = tetris_web_ui_port | default(bookshelf_const_port.tetris.web_ui, true) %}
{% set tag_rex = tetris_tag_rex | default(bookshelf_const_version.tetris_tag_rex, true) %}
---
{{ lookup('template', './../../tailscale/partial/sidecar-compose.yaml.j2', template_vars=dict(
  ts_version = tetris_ts_version | default(bookshelf_const_version.tetris_tailscale, true),
  ts_name = tetris_ts_service_name, ts_conf_dir = conf_dir + '/tailscale'
)) }}

services:
  {{ tetris_service_name }}:
    # https://github.com/spaghetti-coder/tetris/pkgs/container/tetris
    image: ghcr.io/spaghetti-coder/tetris:{{ version }}
    container_name: {{ tetris_service_name }}
    restart: unless-stopped
    labels:
      - wud.watch={{ tetris_wudded }}
      - wud.tag.include={{ tag_rex }}
    env_file:
      - ./secret.env
      - ./main.env
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://localhost:{{ tetris_web_ui_port_int }}"]
      interval: 30s
      timeout: 5s
      retries: 3
{% if tetris_tailscaled %}
    network_mode: "service:{{ tetris_ts_service_name }}"

  {{ tetris_ts_service_name }}:
    <<: *tailscale
{% endif %}
    hostname: {{ tetris_hostname }}
{% if web_ui_port | int > -1 %}
    ports: [{{ web_ui_port }}:{{ tetris_web_ui_port_int }}]
{% else %}
    # ports: [ {{ bookshelf_const_port.tetris.web_ui }}:{{ tetris_web_ui_port_int }} ]
{% endif %}
{% if not (nginx_proxy_enabled | default(false)) %}
    network_mode: bridge
{% else %}
    networks:
      - {{ nginx_proxy_net }}
    environment:
      - VIRTUAL_HOST={{ estro_vhost }}
      - VIRTUAL_PORT={{ estro_web_ui_port_int }}

networks:
  {{ nginx_proxy_net }}:
    external: true
{% endif %}{#                       <- NETMODE END #}
