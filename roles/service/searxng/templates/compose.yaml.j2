{% set version = searxng_version | default(bookshelf_const_version.searxng, true) %}
{% set web_ui_port = searxng_web_ui_port | default(bookshelf_const_port.searxng.web_ui, true) %}
{% set tailscale_version = searxng_ts_version | default(bookshelf_const_version.searxng_tailscale, true) %}
{% set tag_rex = searxng_tag_rex | default(bookshelf_const_version.searxng_tag_rex, true) %}
---
{{ lookup('template', './../../tailscale/partial/sidecar-compose.yaml.j2', template_vars=dict(
  ts_version = searxng_ts_version | default(bookshelf_const_version.searxng_tailscale, true),
  ts_name = searxng_ts_service_name, ts_conf_dir = conf_dir + '/tailscale'
)) }}

services:
  {{ searxng_service_name }}:
    # https://hub.docker.com/r/searxng/searxng/tags
    image: ghcr.io/searxng/searxng:{{ version }}
    container_name: {{ searxng_service_name }}
    restart: unless-stopped
    labels:
      - wud.watch={{ searxng_wudded }}
      - wud.tag.include={{ tag_rex }}
    env_file:
      - ./secret.env
      - ./main.env
    volumes:
      - '{{ conf_dir }}/config:/etc/searxng'
{% if searxng_tailscaled %}
    network_mode: "service:{{ searxng_ts_service_name }}"

  {{ searxng_ts_service_name }}:
    <<: *tailscale
{% endif %}{# searxng_tailscaled #}
    hostname: {{ searxng_hostname }}
{% if web_ui_port | int > -1 %}
    ports:
      - '{{ web_ui_port }}:{{ searxng_web_ui_port_int }}'
{% else %}
    # ports:
    #   - '{{ bookshelf_const_port.searxng.web_ui }}:{{ searxng_web_ui_port_int }}'
{% endif %}
{% if not (nginx_proxy_enabled | default(false)) %}
    network_mode: bridge
{% else %}
    networks:
      - {{ nginx_proxy_net }}
    environment:
      - VIRTUAL_HOST={{ searxng_vhost }}
      - VIRTUAL_PORT={{ searxng_web_ui_port_int }}

networks:
  {{ nginx_proxy_net }}:
    external: true
{% endif %}{# nginx_proxy_enabled #}
