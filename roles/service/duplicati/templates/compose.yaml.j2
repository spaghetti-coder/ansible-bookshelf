{% set version = (duplicati_version | default(bookshelf_const_version.duplicati, true)) %}
{% set web_ui_port = (duplicati_web_ui_port | default(bookshelf_const_port.duplicati.web_ui, true)) %}
{% set same_owner = (duplicati_user == duplicati_owner) %}
{% set data_dir = (same_owner | ternary(duplicati_data_dir, data_dir_abs)) %}
{% set backup_dir = (same_owner | ternary(duplicati_backup_dir, backup_dir_abs)) %}
{% set extra_mounts = (same_owner | ternary(duplicati_extra_mounts, extra_mounts_abs) | default([], true)) %}
{% set tailscale_version = (duplicati_tailscale_version | default(bookshelf_const_version.duplicati_tailscale, true)) %}
{% set tailscale_service = 'duplicati-tailscale' %}
---
services:
  duplicati:
    # https://hub.docker.com/r/linuxserver/duplicati/tags?name=-ls
    image: lscr.io/linuxserver/duplicati:{{ version }}
    container_name: {{ duplicati_service_name }}
    restart: unless-stopped
    env_file:
      - ./secret.env
      - ./main.env
    volumes:
      - {{ data_dir }}:/source
      - {{ backup_dir }}:/backups
{% for extra_mount in extra_mounts %}
      - {{ extra_mount }}
{% endfor %}
      - {{ duplicati_conf_dir }}/config:/config
{% if duplicati_tailscaled %}
    network_mode: "service:{{ tailscale_service }}"

  {{ tailscale_service }}:
    # https://hub.docker.com/r/tailscale/tailscale/tags
    image: tailscale/tailscale:{{ tailscale_version }}
    container_name: {{ duplicati_service_name }}-tailscale
    restart: unless-stopped
    env_file:
      - ./secret.env
      - ./main.env
    volumes:
      - '{{ duplicati_conf_dir }}/tailscale:/var/lib/tailscale'
      # Demo: https://github.com/tailscale-dev/video-code-snippets/blob/main/2025-06-mealie/serve.json
      - ./serve.json:/config/serve.json
    devices:
      - /dev/net/tun:/dev/net/tun
    cap_add:
      - NET_ADMIN
      - SYS_MODULE
{% endif %}{# duplicati_tailscaled #}
    hostname: {{ duplicati_hostname }}
    ports:
      - '{{ web_ui_port }}:{{ duplicati_web_ui_port_int }}'
{% if not (nginx_proxy_enabled | default(false)) %}
    network_mode: bridge    # <- Avoid creating default compose network
{% else %}
    environment:
      - VIRTUAL_HOST={{ duplicati_vhost }}
      - VIRTUAL_PORT={{ duplicati_web_ui_port_int }}
    networks:
      - {{ nginx_proxy_net }}

networks:
  {{ nginx_proxy_net }}:
    external: true
{% endif %}{# nginx_proxy_enabled #}
