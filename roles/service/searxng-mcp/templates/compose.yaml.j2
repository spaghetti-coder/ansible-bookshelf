{% set version = searxng_mcp_version | default(bookshelf_const_version.searxng_mcp, true) %}
{% set tcp_port = searxng_mcp_tcp_port | default(bookshelf_const_port.searxng_mcp.tcp, true) %}
{% set tag_rex = searxng_mcp_tag_rex | default(bookshelf_const_version.searxng_mcp_tag_rex, true) %}
---
{{ lookup('template', './../../tailscale/partial/sidecar-compose.yaml.j2', template_vars=dict(
  ts_version = searxng_mcp_ts_version | default(bookshelf_const_version.searxng_mcp_tailscale, true),
  ts_name = searxng_mcp_ts_service_name, ts_conf_dir = conf_dir + '/tailscale'
)) }}

services:
  {{ searxng_mcp_service_name }}:
    # https://github.com/spaghetti-coder/searxng-mcp/pkgs/container/searxng-mcp
    image: ghcr.io/spaghetti-coder/searxng-mcp:{{ version }}
    container_name: {{ searxng_mcp_service_name }}
    restart: unless-stopped
    labels:
      - wud.watch={{ searxng_mcp_wudded }}
      - wud.tag.include={{ tag_rex }}
    env_file:
      - ./secret.env
      - ./main.env
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://localhost:3000/health"]
      interval: 30s
      timeout: 5s
      retries: 3
{% if searxng_mcp_tailscaled %}
    network_mode: "service:{{ searxng_mcp_ts_service_name }}"

  {{ searxng_mcp_ts_service_name }}:
    <<: *tailscale
{% endif %}{# searxng_mcp_tailscaled #}
    hostname: {{ searxng_mcp_hostname }}
{% if tcp_port | int > -1 %}
    ports:
      - '{{ tcp_port }}:{{ searxng_mcp_tcp_port_int }}'
{% else %}
    # ports:
    #   - '{{ bookshelf_const_port.searxng_mcp.web_ui }}:{{ searxng_mcp_tcp_port_int }}'
{% endif %}
{% if not (nginx_proxy_enabled | default(false)) %}
    network_mode: bridge
{% else %}
    networks:
      - {{ nginx_proxy_net }}
    environment:
      - VIRTUAL_HOST={{ searxng_mcp_vhost }}
      - VIRTUAL_PORT={{ searxng_mcp_tcp_port_int }}

networks:
  {{ nginx_proxy_net }}:
    external: true
{% endif %}{# nginx_proxy_enabled #}
