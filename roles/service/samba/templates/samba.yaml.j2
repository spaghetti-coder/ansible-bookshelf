---
auth:
  - user: foo
    group: foo
    uid: 1000
    gid: 1000
    password: changeme
    # password_file: /run/secrets/foo.pass  # <- If both password and password_file, password wins
  - user: bar
    group: bar
    uid: 1100
    gid: 1200
    password: changeme

global:
  - "force user = foo"
  - "force group = foo"

share:
  - name: foo
    path: /shares
    browsable: yes
    readonly: no
    guestok: no
    validusers: foo
    writelist: foo
    veto: no
    hidefiles: /_*/
    recycle: yes
