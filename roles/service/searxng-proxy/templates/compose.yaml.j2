{% set version = searxng_proxy_version | default(bookshelf_const_version.searxng_proxy, true) %}
{% set web_ui_port = searxng_proxy_web_ui_port | default(bookshelf_const_port.searxng_proxy.web_ui, true) %}
{% set tag_rex = searxng_proxy_tag_rex | default(bookshelf_const_version.searxng_proxy_tag_rex, true) %}
---
{{ lookup('template', './../../tailscale/partial/sidecar-compose.yaml.j2', template_vars=dict(
  ts_version = searxng_proxy_ts_version | default(bookshelf_const_version.searxng_proxy_tailscale, true),
  ts_name = searxng_proxy_ts_service_name, ts_conf_dir = conf_dir + '/tailscale'
)) }}

services:
  {{ searxng_proxy_service_name }}:
    # https://github.com/spaghetti-coder/throttle-proxy/pkgs/container/throttle-proxy
    image: ghcr.io/spaghetti-coder/throttle-proxy:{{ version }}
    container_name: {{ searxng_proxy_service_name }}
    restart: unless-stopped
    labels:
      - wud.watch={{ searxng_proxy_wudded }}
      - wud.tag.include={{ tag_rex }}
    env_file:
      - ./secret.env
      - ./main.env
{% if searxng_proxy_tailscaled %}
    network_mode: "service:{{ searxng_proxy_ts_service_name }}"

  {{ searxng_proxy_ts_service_name }}:
    <<: *tailscale
{% endif %}{# searxng_proxy_tailscaled #}
    hostname: {{ searxng_proxy_hostname }}
{% if web_ui_port | int > -1 %}
    ports:
      - '{{ web_ui_port }}:{{ searxng_proxy_web_ui_port_int }}'
{% else %}
    # ports:
    #   - '{{ bookshelf_const_port.searxng_proxy.web_ui }}:{{ searxng_proxy_web_ui_port_int }}'
{% endif %}
{% if not (nginx_proxy_enabled | default(false)) %}
    network_mode: bridge
{% else %}
    networks:
      - {{ nginx_proxy_net }}
    environment:
      - VIRTUAL_HOST={{ searxng_proxy_vhost }}
      - VIRTUAL_PORT={{ searxng_proxy_web_ui_port_int }}

networks:
  {{ nginx_proxy_net }}:
    external: true
{% endif %}{# nginx_proxy_enabled #}
